{
  "name": "@audio/denoise",
  "version": "0.3.1",
  "type": "module",
  "description": "Noise reduction — gate, spectral subtraction, Wiener, OM-LSA, dehum, declick, decrackle, declip, deesser, dereverb",
  "sideEffects": false,
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "index.js"
  ],
  "scripts": {
    "test": "node test.js",
    "test:all": "npm test --workspaces --if-present && npm test",
    "measure": "node scripts/measure.js",
    "compare": "node scripts/compare.js",
    "publish:all": "npm publish --workspaces && npm publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/denoise.git"
  },
  "keywords": [
    "noise-reduction",
    "denoise",
    "dehum",
    "declick",
    "decrackle",
    "declip",
    "deesser",
    "dereverb",
    "spectral-subtraction",
    "wiener",
    "om-lsa",
    "imcra",
    "audio",
    "audiojs",
    "dsp",
    "speech-enhancement",
    "signal-processing"
  ],
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@audio/denoise-core": "^0.1.0",
    "@audio/vad": "^1.0.0",
    "@audio/noise-estimate": "^1.0.0",
    "@audio/denoise-spectral": "^0.1.0",
    "@audio/denoise-wiener": "^0.1.0",
    "@audio/denoise-omlsa": "^0.1.0",
    "@audio/denoise-dehum": "^0.1.0",
    "@audio/denoise-declick": "^0.1.0",
    "@audio/denoise-decrackle": "^0.1.0",
    "@audio/denoise-declip": "^0.1.0",
    "@audio/denoise-dewind": "^0.1.0",
    "@audio/denoise-deplosive": "^0.1.0",
    "@audio/denoise-deesser": "^0.1.0",
    "@audio/denoise-debreath": "^0.1.0",
    "@audio/denoise-dereverb": "^0.1.0",
    "@audio/denoise-gate": "^0.1.0",
    "@audio/denoise-detect": "^0.1.0",
    "@audio/denoise-repair": "^0.1.0"
  },
  "devDependencies": {
    "audio-lena": "^3.0.0",
    "playwright": "^1.59.1",
    "tst": "^9.4.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/audiojs/denoise/issues"
  },
  "homepage": "https://github.com/audiojs/denoise#readme",
  "main": "index.js"
}
