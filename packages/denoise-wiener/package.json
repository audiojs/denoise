{
  "name": "@audio/denoise-wiener",
  "version": "0.1.8",
  "description": "Wiener filter / MMSE-LSA denoise with decision-directed a-priori SNR",
  "type": "module",
  "sideEffects": false,
  "main": "wiener.js",
  "exports": {
    ".": "./wiener.js",
    "./package.json": "./package.json",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    }
  },
  "files": [
    "wiener.js",
    "audio.js",
    "index.d.ts",
    "audio.d.ts"
  ],
  "dependencies": {
    "@audio/noise-estimate": "^1.0.0",
    "@audio/stft": "^1.0.3"
  },
  "keywords": [
    "audio",
    "dsp",
    "denoise",
    "restoration",
    "wiener"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/denoise.git",
    "directory": "packages/denoise-wiener"
  },
  "homepage": "https://github.com/audiojs/denoise/tree/main/packages/denoise-wiener",
  "bugs": {
    "url": "https://github.com/audiojs/denoise/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "index.d.ts",
  "audio": "./audio.js"
}
