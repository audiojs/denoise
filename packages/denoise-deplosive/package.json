{
  "name": "@audio/denoise-deplosive",
  "version": "0.1.8",
  "description": "De-plosive — detect short low-frequency bursts ('p', 'b' attacks on close mics)",
  "type": "module",
  "sideEffects": false,
  "main": "deplosive.js",
  "exports": {
    ".": "./deplosive.js",
    "./package.json": "./package.json",
    "./audio": {
      "types": "./audio.d.ts",
      "default": "./audio.js"
    }
  },
  "files": [
    "deplosive.js",
    "audio.js",
    "index.d.ts",
    "audio.d.ts"
  ],
  "dependencies": {
    "@audio/biquad": "^1.1.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "denoise",
    "restoration",
    "deplosive"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/denoise.git",
    "directory": "packages/denoise-deplosive"
  },
  "homepage": "https://github.com/audiojs/denoise/tree/main/packages/denoise-deplosive",
  "bugs": {
    "url": "https://github.com/audiojs/denoise/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "index.d.ts",
  "audio": "./audio.js"
}
