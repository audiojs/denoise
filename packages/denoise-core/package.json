{
  "name": "@audio/denoise-core",
  "version": "0.1.2",
  "description": "Internal glue for @audio/denoise-* atoms — STFT (batch/stream/analyse), noise estimation (min-stats, IMCRA), AR modeling, quality metrics. VAD lives in @audio/vad (re-exported here).",
  "type": "module",
  "sideEffects": false,
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./stft": "./stft.js",
    "./util": "./util.js",
    "./noise": "./noise.js",
    "./vad": "./vad.js",
    "./ar": "./ar.js",
    "./quality": "./quality.js"
  },
  "files": [
    "index.js",
    "stft.js",
    "util.js",
    "noise.js",
    "vad.js",
    "ar.js",
    "quality.js"
  ],
  "dependencies": {
    "fourier-transform": "^2.0.0",
    "@audio/vad": "^1.0.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "denoise",
    "stft",
    "vad",
    "noise-estimation"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/denoise.git",
    "directory": "packages/denoise-core"
  },
  "homepage": "https://github.com/audiojs/denoise/tree/main/packages/denoise-core",
  "bugs": {
    "url": "https://github.com/audiojs/denoise/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
