{
  "name": "@audio/denoise-core",
  "version": "0.1.4",
  "description": "Internal glue for @audio/denoise-* atoms — STFT (batch/stream/analyse), quality metrics, dB/linear + stream-writer utils. VAD → @audio/vad, noise estimation → @audio/noise-estimate, LPC/AR → @audio/lpc.",
  "type": "module",
  "sideEffects": false,
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json",
    "./stft": "./stft.js",
    "./util": "./util.js",
    "./quality": "./quality.js"
  },
  "files": [
    "index.js",
    "stft.js",
    "util.js",
    "quality.js"
  ],
  "dependencies": {
    "fourier-transform": "^2.0.0"
  },
  "keywords": [
    "audio",
    "dsp",
    "denoise",
    "stft"
  ],
  "license": "MIT",
  "author": "Dmitry Iv. <dfcreative@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/audiojs/denoise.git",
    "directory": "packages/denoise-core"
  },
  "homepage": "https://github.com/audiojs/denoise/tree/main/packages/denoise-core",
  "bugs": {
    "url": "https://github.com/audiojs/denoise/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
